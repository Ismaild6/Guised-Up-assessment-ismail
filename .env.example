# =============================================================================
# Guised Up — Environment Variables
# Copy sections to backend/.env and mobile/.env as needed
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (docker compose defaults)
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=guisedup
DB_USERNAME=guisedup
DB_PASSWORD=secret

# -----------------------------------------------------------------------------
# Laravel backend (backend/.env)
# -----------------------------------------------------------------------------
APP_NAME=GuisedUp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql

# Embedding service
EMBEDDING_SERVICE_URL=http://localhost:8001
EMBEDDING_USE_MOCK=true

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Python embedding service (embedding-service/)
# -----------------------------------------------------------------------------
# HOST=0.0.0.0
# PORT=8001
# USE_MOCK=true

# -----------------------------------------------------------------------------
# React Native mobile (mobile/.env)
# Use your machine's LAN IP when testing on a physical device
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.10:8000/api
# -----------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# Node.js quick runner (server/) — no .env needed, uses SQLite by default
# -----------------------------------------------------------------------------
